<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= movie.title %> | Rog-Time</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include('partials/nav.ejs') %>

  <main>
    <div class="movie-details">
      <img src="https://image.tmdb.org/t/p/w400<%= movie.poster_path %>" alt="<%= movie.title %>">

      <div class="movie-details-info">
        <h1><%= movie.title %></h1>

        <p><%= movie.release_date ? movie.release_date.split('-')[0] : 'Unknown year' %></p>
        <p><%= movie.runtime %> minutes</p>
        <p>Rating: <%= movie.vote_average %>/10</p>

        <h3>Overview</h3>
        <p><%= movie.overview %></p>
      </div>
    </div>

<section class="movie-comments">
  <h2>Reviews</h2>

  <% if (user) { %>
    <form action="/movies/<%= movie.id %>/comments" method="POST">
      <label for="text">Your review</label>
      <textarea id="text" name="text" required></textarea>
      <button type="submit">Post Review</button>
    </form>
  <% } else { %>
    <p><a href="/auth/sign-in">Sign in</a> to leave a review.</p>
  <% } %>

<% comments.forEach(function(comment) { %>
  <div class="comment">
    <p><strong><%= comment.user.username %></strong></p>
    <p><%= comment.text %></p>
    <p>❤️ <%= comment.favoritedBy ? comment.favoritedBy.length : 0 %></p>

<% if (user) { %>
  <form action="/comments/<%= comment._id %>/favorite?_method=PUT" method="POST">
    <button type="submit">
      <% if (comment.favoritedBy && comment.favoritedBy.some(id => id.toString() === user._id)) { %>
        Unfavorite
      <% } else { %>
        Favorite
      <% } %>
    </button>
  </form>
<% } %>

    <% if (user && comment.user._id.toString() === user._id) { %>
      <form action="/comments/<%= comment._id %>?_method=DELETE" method="POST">
        <button type="submit">Delete</button>
      </form>
    <% } %>
  </div>
<% }) %>

    <a href="/movies">Back to Popular Movies</a>
  </main>
</body>
</html>